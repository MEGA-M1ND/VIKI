# =============================================================================
# Company Brain — environment configuration
# Copy to `.env` and fill in. All keys are read by app/core/config.py.
# Prefix: CB_   (e.g. CB_APP_ENV=local)
# =============================================================================

# --- Application -------------------------------------------------------------
CB_APP_ENV=local                 # local | dev | staging | prod
CB_APP_NAME=company-brain
CB_APP_HOST=0.0.0.0
CB_APP_PORT=8000
CB_LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
CB_LOG_JSON=false                # true => JSON logs (prod); false => console (dev)

# --- Multi-tenancy (single-tenant default for MVP) ---------------------------
CB_DEFAULT_TENANT_ID=default

# --- LLM provider (wired later; placeholders for now) ------------------------
CB_LLM_PROVIDER=openai           # openai | anthropic | azure
CB_LLM_API_KEY=
CB_LLM_MODEL=gpt-4o
CB_LLM_EMBEDDING_MODEL=text-embedding-3-small

# --- Memory store (interface only for MVP; backend chosen later) -------------
CB_MEMORY_BACKEND=in_memory      # in_memory | pgvector | gbrain
CB_MEMORY_DSN=                   # e.g. postgresql://user:pass@host:5432/db

# --- Connectors ---------------------------------------------------------------
CB_GMAIL_CLIENT_ID=
CB_GMAIL_CLIENT_SECRET=
# Gmail tokens are stored at ~/.config/company-brain/gmail_token.json after first auth.

CB_NOTION_API_KEY=
CB_NOTION_TOKEN=                 # alternative to CB_NOTION_API_KEY
CB_NOTION_DATABASE_IDS=          # comma-separated Notion database IDs

CB_SLACK_BOT_TOKEN=

# --- Ingestion tuning --------------------------------------------------------
CB_INGESTION_LOOKBACK_HOURS=24
CB_INGESTION_BATCH_SIZE=50
CB_INGESTION_SCHEDULE_MINUTES=30        # how often the scheduler triggers ingest
CB_HEALTH_CHECK_SCHEDULE_MINUTES=5      # how often health probes run

# --- Retrieval tuning --------------------------------------------------------
CB_RETRIEVAL_DEFAULT_LIMIT=5
CB_RETRIEVAL_MAX_LIMIT=50
CB_CLASSIFIER_CONFIDENCE_THRESHOLD=0.5  # minimum classifier score to proceed with extraction

# --- pgvector backend (set these when CB_MEMORY_BACKEND=pgvector) ------------
CB_MEMORY_DSN=postgresql+asyncpg://viki:viki@localhost:5432/viki

# --- Retrieval: hybrid search + reranker -------------------------------------
CB_RERANKER_ENABLED=true
CB_RERANKER_TOP_K=10
CB_HYBRID_CANDIDATES=20
